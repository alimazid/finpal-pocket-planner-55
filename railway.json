{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "startCommand": "npm run railway:start",
    "healthcheckPath": "/health",
    "variables": {
      "NODE_ENV": "production"
    }
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "LOG_LEVEL": "warn"
      }
    }
  }
}