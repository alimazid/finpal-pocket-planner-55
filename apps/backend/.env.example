# Backend Environment Variables

# Database Configuration
# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://username:password@localhost:5432/finpal"

# Authentication Secrets
# Generate secure random strings for JWT token signing
AUTH_SECRET="your-auth-secret-here-should-be-32-characters-long-minimum"
JWT_SECRET="your-jwt-secret-here-for-additional-auth"

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL="http://localhost:8080"

# External APIs
EXCHANGE_RATE_API_KEY=""

# CORS Configuration
ALLOWED_ORIGINS="http://localhost:8080,http://localhost:3000"

# Penny Integration Configuration
# Penny API endpoint URL
PENNY_API_URL="http://localhost:3000"

# API key for authenticating with Penny
PENNY_API_KEY="your-penny-api-key-here"

# Webhook Security
# Shared secret for HMAC-SHA256 webhook signature verification
WEBHOOK_SECRET="your-webhook-secret-here"

# Google OAuth credentials provided by Penny (shared client approach)
PENNY_CLIENT_ID="your_penny_client_id_here"
PENNY_CLIENT_SECRET="your_penny_client_secret_here"

# OAuth callback URL for Gmail integration
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:8080/gmail/callback"