# Backend Environment Variables

# Database Configuration
# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://username:password@localhost:5432/pocketpenny"

# Authentication Secrets
# Generate secure random strings for JWT token signing
AUTH_SECRET="your-auth-secret-here-should-be-32-characters-long-minimum"
JWT_SECRET="your-jwt-secret-here-for-additional-auth"

# Encryption Key for AES-256-GCM (64-character hex string = 32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL="http://localhost:8080"

# External APIs
EXCHANGE_RATE_API_KEY=""

# CORS Configuration (optional - comma separated list)
# If not set, falls back to FRONTEND_URL
ALLOWED_ORIGINS="http://localhost:8080,https://pocketpenny.site,https://www.pocketpenny.site"

# Penny Integration Configuration
# Penny API endpoint URL
PENNY_API_URL="http://localhost:3000"

# API key for authenticating with Penny
PENNY_API_KEY="your-penny-api-key-here"

# Webhook Security
# Shared secret for HMAC-SHA256 webhook signature verification
WEBHOOK_SECRET="your-webhook-secret-here"

# Google OAuth credentials provided by Penny (shared client approach)
PENNY_CLIENT_ID="your_penny_client_id_here"
PENNY_CLIENT_SECRET="your_penny_client_secret_here"

# OAuth callback URL for Gmail integration
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:8080/gmail/callback"

# Google OAuth credentials for user authentication (separate from Penny integration)
GOOGLE_CLIENT_ID="your-google-oauth-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret-here"
GOOGLE_AUTH_REDIRECT_URI="http://localhost:8080/auth/google/callback"

# Email (Resend)
# Get your API key at https://resend.com
RESEND_API_KEY=""
FROM_EMAIL="noreply@pocketpenny.site"
# Login rate limiting — adjust per environment
# LOGIN_MAX_ATTEMPTS=5        # attempts before lockout (default: 5)
# LOGIN_LOCKOUT_SECONDS=900   # lockout duration in seconds (default: 900 = 15 min; use 60 for dev)
