# Frontend Environment Variables

# Backend API URL (required)
# URL of the Express.js backend API with /api prefix
VITE_API_URL=http://localhost:3001/api

# Webhook URL (required)
# URL for webhook callbacks from external services like Penny
VITE_WEBHOOK_URL=http://localhost:3001/api/gmail/webhook

# Google OAuth Client ID for user authentication (required for Google Sign-In)
# Get this from Google Cloud Console - same as GOOGLE_CLIENT_ID in backend
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id-here

# PostHog Analytics (optional)
# Leave empty to disable analytics
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com